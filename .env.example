# =============================================================
#  Shopping Mall — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mall_admin
POSTGRES_PASSWORD=change_me_postgres

# ─── Per-service DB names (auto-created by init script) ───────
DB_USER_SERVICE=mall_users
DB_PRODUCT_SERVICE=mall_products
DB_ORDER_SERVICE=mall_orders
DB_PAYMENT_SERVICE=mall_payments
DB_VENDOR_SERVICE=mall_vendors
DB_INVENTORY_SERVICE=mall_inventory
DB_NOTIFICATION_SERVICE=mall_notifications
DB_SHIPPING_SERVICE=mall_shipping
DB_REVIEW_SERVICE=mall_reviews
DB_DISCOUNT_SERVICE=mall_discounts
DB_WISHLIST_SERVICE=mall_wishlists
DB_ADMIN_SERVICE=mall_admin
DB_SEARCH_SERVICE=mall_search
DB_MEDIA_SERVICE=mall_media

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Apache Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=mall-group

# ─── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URI=http://elasticsearch:9200

# ─── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PRODUCTS=products
MINIO_BUCKET_VENDORS=vendors
MINIO_BUCKET_USERS=users

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_256bit_secret_key_here_change_in_production
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── OAuth2 — Google ──────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:8081/login/oauth2/code/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── OAuth2 — GitHub ──────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:8081/login/oauth2/code/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Stripe ───────────────────────────────────────────────────
# Use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── SMTP / Email ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@shoppingmall.com

# ─── Zipkin (Distributed Tracing) ─────────────────────────────
ZIPKIN_BASE_URL=http://zipkin:9411

# ─── Service URLs (internal) ──────────────────────────────────
USER_SERVICE_URL=http://user-service:8081
PRODUCT_SERVICE_URL=http://product-service:8082
ORDER_SERVICE_URL=http://order-service:8083
PAYMENT_SERVICE_URL=http://payment-service:8084
VENDOR_SERVICE_URL=http://vendor-service:8085
INVENTORY_SERVICE_URL=http://inventory-service:8086
NOTIFICATION_SERVICE_URL=http://notification-service:8087
SHIPPING_SERVICE_URL=http://shipping-service:8088
REVIEW_SERVICE_URL=http://review-service:8089
DISCOUNT_SERVICE_URL=http://discount-service:8090
WISHLIST_SERVICE_URL=http://wishlist-service:8091
ADMIN_SERVICE_URL=http://admin-service:8092
SEARCH_SERVICE_URL=http://search-service:8093
MEDIA_SERVICE_URL=http://media-service:8094

# ─── Spring Profiles ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
